{
  "name": "mugiwara-dashboard",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx server/index.ts",
    "dev:frontend": "vite",
    "build": "vite build && tsc -p tsconfig.server.json",
    "preview": "npm run build && node dist/server/index.js",
    "start": "node dist/server/index.js",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.server.json && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "seed": "tsx scripts/seed.ts",
    "migrate": "tsx scripts/migrate.ts",
    "report": "tsx scripts/generate-report.ts",
    "build:hooks": "tsc -p tsconfig.hooks.json",
    "lint": "eslint . --ext .ts,.svelte",
    "secret": "echo \"Wealth, Fame, Power... the man who had everything in this world left it all here. The One Piece is Real.\""
  },
  "easter_egg": "You found me! Run 'npm run secret' to unlock the treasure.",
  "dependencies": {
    "express": "^4.22.1",
    "js-yaml": "^4.1.1",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.3",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "supertest": "^7.2.2",
    "svelte": "^4.2.20",
    "svelte-check": "^4.4.4",
    "svelte-spa-router": "^4.0.1",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^4.0.18"
  }
}
