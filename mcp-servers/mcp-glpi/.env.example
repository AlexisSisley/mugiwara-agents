# GLPI REST API Configuration
# ----------------------------
# URL de votre instance GLPI (sans slash final)
GLPI_URL=https://glpi.votre-entreprise.com

# App-Token : Configuration > Generale > API > Clients API
GLPI_APP_TOKEN=votre-app-token

# User-Token : Administration > Utilisateurs > [user] > Parametres > Jeton API distant
GLPI_USER_TOKEN=votre-user-token

# Mode lecture seule (true par defaut) — desactive update/followup
GLPI_READ_ONLY=true
